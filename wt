#!/bin/bash

set -e

usage() {
    cat << EOF
Usage: wt <command> [options]

Commands:
    clone     Clone a remote into the bare-repo + worktrees layout:
              wt clone <repo-url> [target-dir]
              Creates <target-dir>/{.bare,.git,<default-branch>}; target-dir
              defaults to the repo name. See docs/git/worktrees.md.
    init      Create a new local repo in the bare-repo + worktrees layout:
              wt init <projname>
              Creates <projname>/{.bare,.git,main} and seeds main with an
              empty initial commit. Fails if <projname> already exists.
    status    Show clean status overview of all worktrees
              -v, --verbose  Show detailed file lists and commits
    list      List all worktrees (with lock status)
    locked    List only locked worktrees
    add       Create a worktree for a branch (sibling of the current worktree):
              wt add <branch> [<start-point>]
              Checks out an existing local branch, tracks a remote branch of
              the same name, or creates a new branch off <start-point>
              (default: HEAD). Worktree dir is <root>/<branch>.
    checkout  Create worktree from a remote branch:
              wt checkout <branch> <parent-dir>
              Uses the remote tracked by the current branch.
    cleanup   Remove all locked worktrees
    lock      Lock worktree(s): wt lock <path> [path2 ...]
              --clean        Lock all clean worktrees with remote (except primary)
    unlock    Unlock worktree(s): wt unlock <path> [path2 ...]
    run       Run command in worktrees: wt run [--locked|--all] -- <command>
    open      Open a tmux window with a 2x2 pane grid for a worktree:
              wt open <worktree>
              <worktree> may be a path, branch name, or directory name.
              The window is named after the worktree's branch.
    open-pr   Open a tmux window for a GitHub PR, creating its worktree first:
              wt open-pr <number>
              Resolves the PR's head branch via gh, checks it out as a worktree
              if needed (forks use a pr-<number> branch), then opens like 'open'.
    close     Close the tmux window(s) of a worktree and lock it:
              wt close <worktree>
              <worktree> may be a path, branch name, or directory name.
    help      Show this help

Examples:
    wt clone git@github.com:you/proj.git
    wt clone git@github.com:you/proj.git ~/Git/proj
    wt init my-new-project
    wt status
    wt status -v
    wt list
    wt locked
    wt checkout foobar ../
    wt add my-feature
    wt add hotfix origin/main
    wt cleanup
    wt lock --clean
    wt lock /path/to/worktree
    wt unlock /path/to/worktree
    wt lock /path/worktree-* /other/worktree
    wt unlock */worktree-{1,2}
    wt run -- git clean -dfx
    wt run --locked -- git status
    wt run --all -- npm install
    wt open ../my-feature-worktree
    wt open my-feature-branch
    wt open-pr 1234
    wt close my-feature-branch
EOF
}

require_repo() {
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        echo "Error: Not in a git repository" >&2
        exit 1
    fi
}

get_worktrees() {
    git worktree list --porcelain | awk '
    function emit() {
        if (path != "") {
            printf "%s\t%d\n", path, locked;
        }
    }
    BEGIN {
        path = "";
        locked = 0;
    }
    {
        key = $1;
        if (key == "worktree") {
            emit();
            path = substr($0, index($0, " ") + 1);
            locked = 0;
        } else if (key == "locked") {
            locked = 1;
        } else if ($0 == "") {
            emit();
            path = "";
            locked = 0;
        }
    }
    END {
        emit();
    }'
}

get_worktree_branches() {
    git worktree list --porcelain | awk '
    function emit() {
        if (path != "") {
            printf "%s\t%s\n", path, branch;
        }
    }
    BEGIN {
        path = "";
        branch = "";
    }
    {
        if ($1 == "worktree") {
            emit();
            path = substr($0, index($0, " ") + 1);
            branch = "";
        } else if ($1 == "branch") {
            branch = substr($0, index($0, " ") + 1);
            sub(/^refs\/heads\//, "", branch);
        } else if ($1 == "detached") {
            branch = "(detached)";
        } else if ($0 == "") {
            emit();
            path = "";
            branch = "";
        }
    }
    END {
        emit();
    }'
}

list_worktrees() {
    require_repo

    git worktree list
}

list_locked() {
    require_repo

    local found=0
    while IFS=$'\t' read -r formatted path locked_flag; do
        if [ "$locked_flag" -eq 1 ]; then
            echo "$formatted"
            found=1
        fi
    done < <(paste <(git worktree list) <(get_worktrees))

    if [ "$found" -eq 0 ]; then
        echo "No locked worktrees found"
    fi
}

status_worktrees() {
    require_repo

    local verbose=0
    if [ "${1:-}" = "-v" ] || [ "${1:-}" = "--verbose" ]; then
        verbose=1
    fi

    local RED='\033[0;31m'
    local GREEN='\033[0;32m'
    local YELLOW='\033[1;33m'
    local BLUE='\033[0;34m'
    local CYAN='\033[0;36m'
    local GRAY='\033[0;90m'
    local BOLD='\033[1m'
    local RESET='\033[0m'

    local worktree_count=0
    while IFS=$'\t' read -r wt_path locked; do
        ((++worktree_count))

        local wt_name
        wt_name=$(basename "$wt_path")
        if [ "$locked" -eq 1 ]; then
            echo -e "${BOLD}${YELLOW}🔒 $wt_name${RESET} ${GRAY}(locked)${RESET}"
        else
            echo -e "${BOLD}${CYAN}$wt_name${RESET}"
        fi
        echo -e "${GRAY}   $wt_path${RESET}"

        (
            cd "$wt_path" || exit 0

            local branch
            branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null || echo "unknown")
            echo -e "   ${BLUE}branch:${RESET} $branch"

            local upstream
            upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)
            if [ -n "$upstream" ]; then
                local ahead behind
                ahead=$(git rev-list --count '@{u}'..HEAD 2>/dev/null || echo "0")
                behind=$(git rev-list --count HEAD..'@{u}' 2>/dev/null || echo "0")

                if [ "$ahead" -gt 0 ] || [ "$behind" -gt 0 ]; then
                    local tracking_info=""
                    [ "$ahead" -gt 0 ] && tracking_info="${GREEN}↑$ahead${RESET}"
                    [ "$behind" -gt 0 ] && tracking_info="${tracking_info}${tracking_info:+ }${RED}↓$behind${RESET}"
                    echo -e "   ${BLUE}remote:${RESET} $upstream ($tracking_info)"

                    if [ "$verbose" -eq 1 ] && [ "$ahead" -gt 0 ]; then
                        echo -e "   ${GRAY}ahead commits:${RESET}"
                        git log --oneline '@{u}'..HEAD 2>/dev/null | while read -r commit_line; do
                            echo -e "     ${GREEN}+${RESET} $commit_line"
                        done
                    fi

                    if [ "$verbose" -eq 1 ] && [ "$behind" -gt 0 ]; then
                        echo -e "   ${GRAY}behind commits:${RESET}"
                        git log --oneline HEAD..'@{u}' 2>/dev/null | while read -r commit_line; do
                            echo -e "     ${RED}-${RESET} $commit_line"
                        done
                    fi
                else
                    echo -e "   ${BLUE}remote:${RESET} $upstream ${GREEN}✓${RESET}"
                fi
            else
                echo -e "   ${BLUE}remote:${RESET} ${YELLOW}local only${RESET}"
            fi

            local staged unstaged untracked
            staged=$(git diff --cached --numstat 2>/dev/null | wc -l)
            unstaged=$(git diff --numstat 2>/dev/null | wc -l)
            untracked=$(git ls-files --others --exclude-standard 2>/dev/null | wc -l)

            if [ "$staged" -eq 0 ] && [ "$unstaged" -eq 0 ] && [ "$untracked" -eq 0 ]; then
                echo -e "   ${BLUE}status:${RESET} ${GREEN}clean${RESET}"
            else
                local status_parts=()
                [ "$staged" -gt 0 ] && status_parts+=("${GREEN}$staged staged${RESET}")
                [ "$unstaged" -gt 0 ] && status_parts+=("${YELLOW}$unstaged modified${RESET}")
                [ "$untracked" -gt 0 ] && status_parts+=("${RED}$untracked untracked${RESET}")

                echo -e "   ${BLUE}status:${RESET} $(IFS=', '; echo -e "${status_parts[*]}")"

                if [ "$verbose" -eq 1 ] && [ "$staged" -gt 0 ]; then
                    echo -e "   ${GRAY}staged files:${RESET}"
                    git diff --cached --name-status 2>/dev/null | while read -r status_char file; do
                        echo -e "     ${GREEN}$status_char${RESET} $file"
                    done
                fi

                if [ "$verbose" -eq 1 ] && [ "$unstaged" -gt 0 ]; then
                    echo -e "   ${GRAY}modified files:${RESET}"
                    git diff --name-status 2>/dev/null | while read -r status_char file; do
                        echo -e "     ${YELLOW}$status_char${RESET} $file"
                    done
                fi

                if [ "$verbose" -eq 1 ] && [ "$untracked" -gt 0 ]; then
                    echo -e "   ${GRAY}untracked files:${RESET}"
                    git ls-files --others --exclude-standard 2>/dev/null | while read -r file; do
                        echo -e "     ${RED}?${RESET} $file"
                    done
                fi
            fi
        ) || true

        echo
    done < <(get_worktrees)

    if [ "$worktree_count" -eq 0 ]; then
        echo "No worktrees found"
    fi
}

cleanup_locked() {
    require_repo

    local locked_worktrees=()
    while IFS=$'\t' read -r path status; do
        if [ "$status" -eq 1 ]; then
            locked_worktrees+=("$path")
        fi
    done < <(get_worktrees)

    if [ ${#locked_worktrees[@]} -eq 0 ]; then
        echo "No locked worktrees found"
        return 0
    fi

    echo "Found locked worktrees:"
    printf '  %s\n' "${locked_worktrees[@]}"
    echo

    read -p "Remove all locked worktrees? [y/N]: " -n 1 -r
    echo

    if [[ $REPLY =~ ^[Yy]$ ]]; then
        for worktree_path in "${locked_worktrees[@]}"; do
            echo "Removing: $worktree_path"
            git worktree remove -f -f "$worktree_path" --force
        done
        echo "Cleanup complete"
    else
        echo "Cleanup cancelled"
    fi
}

lock_worktree() {
    require_repo

    local clean_mode=0
    if [ "${1:-}" = "--clean" ]; then
        clean_mode=1
        shift
    fi

    if [ $clean_mode -eq 0 ] && [ $# -eq 0 ]; then
        echo "Error: Please specify at least one worktree path" >&2
        exit 1
    fi

    declare -A worktree_status
    while IFS=$'\t' read -r wt_path status; do
        worktree_status["$wt_path"]="$status"
    done < <(get_worktrees)

    local paths_to_lock=()

    if [ $clean_mode -eq 1 ]; then
        local primary_worktree
        primary_worktree=$(git worktree list --porcelain | awk '/^worktree / {print substr($0, 10); exit}')

        while IFS=$'\t' read -r wt_path locked; do
            if [ "$wt_path" = "$primary_worktree" ]; then
                continue
            fi

            if [ "$locked" -eq 1 ]; then
                continue
            fi

            (
                cd "$wt_path" || exit 1

                local upstream
                upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)
                if [ -z "$upstream" ]; then
                    exit 1
                fi

                local staged unstaged untracked
                staged=$(git diff --cached --numstat 2>/dev/null | wc -l)
                unstaged=$(git diff --numstat 2>/dev/null | wc -l)
                untracked=$(git ls-files --others --exclude-standard 2>/dev/null | wc -l)

                if [ "$staged" -eq 0 ] && [ "$unstaged" -eq 0 ] && [ "$untracked" -eq 0 ]; then
                    exit 0
                else
                    exit 1
                fi
            ) && paths_to_lock+=("$wt_path")
        done < <(get_worktrees)
    else
        for path in "$@"; do
            if [ ! -d "$path" ]; then
                echo "Warning: Skipping non-existent path: $path" >&2
            else
                local abs_path
                abs_path=$(cd "$path" && pwd)

                if [ "${worktree_status[$abs_path]}" = "1" ]; then
                    echo "Already locked: $path"
                elif [ -n "${worktree_status[$abs_path]+_}" ]; then
                    paths_to_lock+=("$path")
                else
                    echo "Warning: Not a worktree: $path" >&2
                fi
            fi
        done
    fi

    if [ ${#paths_to_lock[@]} -eq 0 ]; then
        echo "No worktrees to lock"
        exit 0
    fi

    if [ ${#paths_to_lock[@]} -gt 1 ] || [ $clean_mode -eq 1 ]; then
        echo "About to lock ${#paths_to_lock[@]} worktree(s):"
        printf '  %s\n' "${paths_to_lock[@]}"
        echo
        read -p "Continue? [y/N]: " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "Operation cancelled"
            exit 0
        fi
    fi

    for path in "${paths_to_lock[@]}"; do
        git worktree lock "$path"
        echo "Locked: $path"
    done
}

unlock_worktree() {
    require_repo

    if [ $# -eq 0 ]; then
        echo "Error: Please specify at least one worktree path" >&2
        exit 1
    fi

    declare -A worktree_status
    while IFS=$'\t' read -r wt_path status; do
        worktree_status["$wt_path"]="$status"
    done < <(get_worktrees)

    local paths_to_unlock=()
    for path in "$@"; do
        if [ ! -d "$path" ]; then
            echo "Warning: Skipping non-existent path: $path" >&2
        else
            local abs_path
            abs_path=$(cd "$path" && pwd)

            if [ "${worktree_status[$abs_path]}" = "0" ]; then
                echo "Not locked: $path"
            elif [ "${worktree_status[$abs_path]}" = "1" ]; then
                paths_to_unlock+=("$path")
            else
                echo "Warning: Not a worktree: $path" >&2
            fi
        fi
    done

    if [ ${#paths_to_unlock[@]} -eq 0 ]; then
        echo "No worktrees to unlock"
        exit 0
    fi

    if [ ${#paths_to_unlock[@]} -gt 1 ]; then
        echo "About to unlock ${#paths_to_unlock[@]} worktree(s):"
        printf '  %s\n' "${paths_to_unlock[@]}"
        echo
        read -p "Continue? [y/N]: " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "Operation cancelled"
            exit 0
        fi
    fi

    for path in "${paths_to_unlock[@]}"; do
        git worktree unlock "$path"
        echo "Unlocked: $path"
    done
}

run_in_worktrees() {
    require_repo

    local mode="unlocked"
    local command_args=()
    local found_separator=false

    while [ $# -gt 0 ]; do
        case "$1" in
            --locked)
                mode="locked"
                shift
                ;;
            --all)
                mode="all"
                shift
                ;;
            --)
                found_separator=true
                shift
                command_args=("$@")
                break
                ;;
            *)
                echo "Error: Unknown option '$1'. Use -- to separate command" >&2
                exit 1
                ;;
        esac
    done

    if [ "$found_separator" = false ]; then
        echo "Error: Missing -- separator before command" >&2
        echo "Usage: wt run [--locked|--all] -- <command>" >&2
        exit 1
    fi

    if [ ${#command_args[@]} -eq 0 ]; then
        echo "Error: No command specified after --" >&2
        exit 1
    fi

    local worktree_paths=()
    while IFS=$'\t' read -r wt_path status; do
        case "$mode" in
            locked)
                [ "$status" -eq 1 ] && worktree_paths+=("$wt_path")
                ;;
            unlocked)
                [ "$status" -eq 0 ] && worktree_paths+=("$wt_path")
                ;;
            all)
                worktree_paths+=("$wt_path")
                ;;
        esac
    done < <(get_worktrees)

    if [ ${#worktree_paths[@]} -eq 0 ]; then
        echo "No $mode worktrees found"
        exit 0
    fi

    echo "About to run command in ${#worktree_paths[@]} $mode worktree(s):"
    printf '  %s\n' "${worktree_paths[@]}"
    echo
    echo "Command: ${command_args[*]}"
    echo
    read -p "Continue? [y/N]: " -n 1 -r
    echo

    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Operation cancelled"
        exit 0
    fi

    local failed=0
    for wt_path in "${worktree_paths[@]}"; do
        echo
        echo "==> Running in: $wt_path"
        if (cd "$wt_path" && "${command_args[@]}"); then
            echo "==> Success: $wt_path"
        else
            echo "==> Failed: $wt_path (exit code: $?)" >&2
            ((failed++))
        fi
    done

    echo
    if [ $failed -eq 0 ]; then
        echo "All commands completed successfully"
    else
        echo "Warning: $failed command(s) failed" >&2
        exit 1
    fi
}

# Clone a remote into the bare-repo + worktrees layout from docs/git/worktrees.md
# ("Cloning an existing remote"): the git database lives in an un-checked-out .bare,
# a one-line .git pointer makes the root behave like a repo, and every branch — main
# included — is an equal, removable worktree. Runs outside any repo (it creates one),
# so no require_repo here.
clone_repo() {
    if [ $# -lt 1 ]; then
        echo "Error: Usage: wt clone <repo-url> [target-dir]" >&2
        exit 1
    fi

    local url="$1"
    local target="${2:-}"

    # Derive the project dir from the URL when not given: drop a trailing .git and
    # slash, then take the final path segment (or the scp-style host:path segment).
    if [ -z "$target" ]; then
        target="${url%.git}"
        target="${target%/}"
        target="${target##*/}"
        target="${target##*:}"
    fi

    if [ -z "$target" ]; then
        echo "Error: Could not derive a target directory from '$url'; pass one explicitly" >&2
        exit 1
    fi

    if [ -e "$target" ]; then
        echo "Error: Target path already exists: $target" >&2
        exit 1
    fi

    echo "Cloning into bare-repo + worktrees layout:"
    echo "  repo: $url"
    echo "  root: $target"
    echo

    mkdir -p "$target"

    # 1. The git database, never checked out.
    git clone --bare "$url" "$target/.bare"

    # 2. The one-line pointer that lets git commands run from the root.
    printf 'gitdir: ./.bare\n' > "$target/.git"

    # 3. A bare clone fetches into refs/heads/*; without this refspec `git fetch`
    #    never populates origin/* and worktrees won't track upstream as expected.
    git --git-dir="$target/.bare" config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'

    # 4. Materialize the default branch (per the clone's HEAD) as the first
    #    worktree; fall back to the conventional 'main' if HEAD can't be read.
    local default_branch
    default_branch=$(git --git-dir="$target/.bare" symbolic-ref --short HEAD 2>/dev/null || echo main)
    git -C "$target" worktree add "$default_branch"

    echo
    echo "Done: $target/$default_branch (worktree '$default_branch')"
}

# Create a brand-new LOCAL repo in the bare-repo + worktrees layout (no remote).
# Sibling of clone: where clone copies an existing remote, init git-inits an
# empty .bare and seeds 'main' with an initial empty commit, leaving a layout
# that's immediately usable. Runs outside any repo (it creates one), so no
# require_repo.
init_repo() {
    if [ $# -lt 1 ]; then
        echo "Error: Usage: wt init <projname>" >&2
        exit 1
    fi

    local target="$1"
    local branch="main"

    if [ -e "$target" ]; then
        echo "Error: Target path already exists: $target" >&2
        exit 1
    fi

    echo "Initializing new repo in bare-repo + worktrees layout:"
    echo "  root:   $target"
    echo "  branch: $branch"
    echo

    mkdir -p "$target"

    # 1. The git database, never checked out.
    git init --bare "$target/.bare"

    # 2. The one-line pointer that lets git commands run from the root.
    printf 'gitdir: ./.bare\n' > "$target/.git"

    # 3. Name the default branch 'main' regardless of the user's
    #    init.defaultBranch, so the layout matches the rest of the tooling.
    git --git-dir="$target/.bare" symbolic-ref HEAD "refs/heads/$branch"

    # 4. Materialize 'main' as an orphan worktree (the repo has no commits yet)
    #    and seed it with an empty initial commit so it's ready to use.
    git -C "$target" worktree add --orphan -b "$branch" "$branch"
    git -C "$target/$branch" commit --allow-empty -m "Initial commit"

    echo
    echo "Done: $target/$branch (worktree '$branch')"
}

checkout_worktree() {
    require_repo

    if [ $# -lt 2 ]; then
        echo "Error: Usage: wt checkout <branch> <parent-dir>" >&2
        exit 1
    fi

    local branch="$1"
    local parent_dir="$2"

    if [ ! -d "$parent_dir" ]; then
        echo "Error: Parent directory does not exist: $parent_dir" >&2
        exit 1
    fi

    local target_path
    if [[ "$parent_dir" == */ ]]; then
        target_path="${parent_dir}${branch}"
    else
        target_path="${parent_dir}/${branch}"
    fi

    if [ -e "$target_path" ]; then
        echo "Error: Target path already exists: $target_path" >&2
        exit 1
    fi

    local remote
    local current_upstream
    current_upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)
    if [ -n "$current_upstream" ]; then
        remote="${current_upstream%%/*}"
    else
        local remote_count
        remote_count=$(git remote | wc -l)
        if [ "$remote_count" -eq 0 ]; then
            echo "Error: No remotes configured" >&2
            exit 1
        elif [ "$remote_count" -eq 1 ]; then
            remote=$(git remote)
        else
            echo "Error: Current branch has no upstream and multiple remotes are configured." >&2
            echo "Set an upstream for the current branch or run from a branch that tracks a remote." >&2
            echo "Configured remotes:" >&2
            git remote | sed 's/^/  /' >&2
            exit 1
        fi
    fi

    if ! git show-ref --verify --quiet "refs/remotes/$remote/$branch"; then
        echo "Branch $remote/$branch not found locally; fetching..."
        if ! git fetch "$remote" "$branch" 2>/dev/null; then
            echo "Error: Branch '$branch' does not exist on remote '$remote'" >&2
            exit 1
        fi
        if ! git show-ref --verify --quiet "refs/remotes/$remote/$branch"; then
            echo "Error: Branch '$branch' does not exist on remote '$remote'" >&2
            exit 1
        fi
    fi

    echo "Creating worktree:"
    echo "  branch: $branch"
    echo "  path:   $target_path"
    echo "  base:   $remote/$branch"
    echo

    git worktree add -b "$branch" "$target_path" "$remote/$branch"
}

# Create a worktree for <branch> as a sibling of the current worktree. Unlike
# checkout (remote branch, explicit parent dir) this is the general creator: it
# reuses an existing local branch, tracks a remote branch of the same name, or
# cuts a new branch off <start-point> (HEAD when omitted).
add_worktree() {
    require_repo

    if [ $# -lt 1 ]; then
        echo "Error: Usage: wt add <branch> [<start-point>]" >&2
        exit 1
    fi

    local branch="$1"
    local start_point="${2:-}"

    local existing
    if existing=$(worktree_path_for_branch "$branch"); then
        echo "Error: A worktree for '$branch' already exists: $existing" >&2
        exit 1
    fi

    local root
    root=$(worktree_root) || { echo "Error: Could not determine worktree root" >&2; exit 1; }
    local target_path="$root/$branch"

    if [ -e "$target_path" ]; then
        echo "Error: Target path already exists: $target_path" >&2
        exit 1
    fi

    if git show-ref --verify --quiet "refs/heads/$branch"; then
        echo "Creating worktree for existing branch '$branch' at $target_path"
        git worktree add "$target_path" "$branch"
    elif [ -n "$start_point" ]; then
        echo "Creating worktree '$branch' (off $start_point) at $target_path"
        git worktree add -b "$branch" "$target_path" "$start_point"
    else
        # No local branch and no explicit base: track a remote branch of the
        # same name if one exists, otherwise branch off the current HEAD.
        local remote_ref="" r
        for r in $(git remote); do
            if git show-ref --verify --quiet "refs/remotes/$r/$branch"; then
                remote_ref="$r/$branch"
                break
            fi
        done
        if [ -n "$remote_ref" ]; then
            echo "Creating worktree '$branch' tracking $remote_ref at $target_path"
            git worktree add -b "$branch" "$target_path" "$remote_ref"
        else
            echo "Creating worktree '$branch' (new branch off HEAD) at $target_path"
            git worktree add -b "$branch" "$target_path"
        fi
    fi
}

# Echo the directory that holds the worktrees. In the bare-repo layout every
# worktree (main included) is a sibling under this root, so a new worktree for
# branch <b> belongs at <root>/<b>.
worktree_root() {
    local top common
    if top=$(git rev-parse --show-toplevel 2>/dev/null); then
        dirname "$top"
        return 0
    fi
    # The bare root has no work tree of its own; fall back to the common git dir.
    if common=$(git rev-parse --git-common-dir 2>/dev/null); then
        common=$(cd "$common" 2>/dev/null && pwd) || return 1
        dirname "$common"
        return 0
    fi
    return 1
}

# Echo the path of the worktree currently checked out on <branch>, or return 1
# if none has it. Non-fatal counterpart to resolve_worktree.
worktree_path_for_branch() {
    local want="$1" p b
    while IFS=$'\t' read -r p b; do
        if [ "$b" = "$want" ]; then
            echo "$p"
            return 0
        fi
    done < <(get_worktree_branches)
    return 1
}

# Resolve a worktree target (path, branch name, or directory name) into the
# globals RESOLVED_PATH and RESOLVED_BRANCH. Exits with an error if the target
# matches no worktree or is ambiguous.
resolve_worktree() {
    local target="$1"

    # If the argument is a directory, resolve it to the worktree root it lives in.
    local target_abs=""
    if [ -d "$target" ]; then
        target_abs=$(git -C "$target" rev-parse --show-toplevel 2>/dev/null || (cd "$target" && pwd))
    fi

    RESOLVED_PATH=""
    RESOLVED_BRANCH=""
    local matched_path="" matched_branch=""
    local name_matches=()

    while IFS=$'\t' read -r p b; do
        if [ -n "$target_abs" ] && [ "$p" = "$target_abs" ]; then
            matched_path="$p"
            matched_branch="$b"
            break
        fi
        if [ "$b" = "$target" ] || [ "$(basename "$p")" = "$target" ]; then
            name_matches+=("$p"$'\t'"$b")
        fi
    done < <(get_worktree_branches)

    if [ -n "$matched_path" ]; then
        RESOLVED_PATH="$matched_path"
        RESOLVED_BRANCH="$matched_branch"
    elif [ ${#name_matches[@]} -eq 1 ]; then
        IFS=$'\t' read -r RESOLVED_PATH RESOLVED_BRANCH <<< "${name_matches[0]}"
    elif [ ${#name_matches[@]} -gt 1 ]; then
        echo "Error: '$target' matches multiple worktrees:" >&2
        printf '  %s\n' "${name_matches[@]%%$'\t'*}" >&2
        exit 1
    else
        echo "Error: No worktree found matching: $target" >&2
        echo "Run 'wt list' to see available worktrees" >&2
        exit 1
    fi
}

open_window() {
    require_repo

    if [ -z "${TMUX:-}" ]; then
        echo "Error: Not inside a tmux session" >&2
        exit 1
    fi

    if [ $# -lt 1 ]; then
        echo "Error: Usage: wt open <worktree>" >&2
        echo "  <worktree> may be a path, branch name, or worktree directory name" >&2
        exit 1
    fi

    resolve_worktree "$1"
    local wt_path="$RESOLVED_PATH" branch="$RESOLVED_BRANCH"

    local win_name="$branch"
    if [ -z "$win_name" ] || [ "$win_name" = "(detached)" ]; then
        win_name=$(basename "$wt_path")
    fi

    # Open a new window rooted at the worktree, then carve it into a 2x2 grid
    # of panes (mirrors the '#' binding in ~/.tmux.conf), all sharing the cwd.
    local window_id
    window_id=$(tmux new-window -P -F '#{window_id}' -c "$wt_path" -n "$win_name")
    tmux split-window -h -c "$wt_path"
    tmux select-pane -L
    tmux split-window -v -c "$wt_path"
    tmux select-pane -R
    tmux split-window -v -c "$wt_path"
    tmux select-pane -t '{top-left}'

    # Shells may rename the window from their prompt hook as the panes start up,
    # so set the name explicitly once everything is in place to make it stick.
    tmux rename-window -t "$window_id" "$win_name"
}

# Open a tmux window for a GitHub PR. Resolves the PR's head branch with gh,
# materializes a worktree for it if one doesn't exist yet, then hands off to
# open_window so the PR opens exactly like 'wt open'.
open_pr() {
    require_repo

    if [ -z "${TMUX:-}" ]; then
        echo "Error: Not inside a tmux session" >&2
        exit 1
    fi

    if [ $# -lt 1 ]; then
        echo "Error: Usage: wt open-pr <number>" >&2
        exit 1
    fi

    if ! command -v gh >/dev/null 2>&1; then
        echo "Error: 'gh' (GitHub CLI) is required for open-pr but was not found" >&2
        exit 1
    fi

    local pr="$1"

    # One gh call for the head branch and whether it comes from a fork.
    local pr_info head_branch cross_repo
    if ! pr_info=$(gh pr view "$pr" --json headRefName,isCrossRepository \
            -q '.headRefName + "\t" + (.isCrossRepository | tostring)' 2>&1); then
        echo "Error: Could not read PR #$pr via gh:" >&2
        printf '%s\n' "$pr_info" | sed 's/^/  /' >&2
        exit 1
    fi
    head_branch="${pr_info%%$'\t'*}"
    cross_repo="${pr_info##*$'\t'}"

    if [ -z "$head_branch" ]; then
        echo "Error: Could not determine head branch for PR #$pr" >&2
        exit 1
    fi

    # Same-repo PRs reuse the author's branch name so the worktree tracks origin
    # and shows up in `wt status`. Fork PRs get a pr-<number> branch: their head
    # isn't on origin under that name, and the name (e.g. 'main') may collide.
    local branch
    if [ "$cross_repo" = "true" ]; then
        branch="pr-$pr"
    else
        branch="$head_branch"
    fi

    # Already checked out somewhere? Just open it.
    local existing
    if existing=$(worktree_path_for_branch "$branch"); then
        echo "Worktree for PR #$pr already exists: $existing"
        open_window "$branch"
        return
    fi

    local root
    root=$(worktree_root) || { echo "Error: Could not determine worktree root" >&2; exit 1; }
    local target_path="$root/$branch"
    if [ -e "$target_path" ]; then
        echo "Error: Target path already exists: $target_path" >&2
        exit 1
    fi

    echo "Setting up worktree for PR #$pr (head '$head_branch'):"
    echo "  path: $target_path"

    if git show-ref --verify --quiet "refs/heads/$branch"; then
        echo "  from: existing local branch '$branch'"
        echo
        git worktree add "$target_path" "$branch"
    elif [ "$cross_repo" = "true" ]; then
        # Fork PR: the head isn't a branch on origin, but GitHub still exposes it
        # at refs/pull/<n>/head. Fetch that and pin a local branch to it.
        echo "  from: origin pull/$pr/head (fork)"
        echo
        git fetch origin "pull/$pr/head"
        git worktree add -b "$branch" "$target_path" FETCH_HEAD
    else
        # Same-repo PR: the head is a branch on origin. Fetch it, then track
        # origin/<branch> when the remote-tracking ref exists (so `wt status`
        # and pulls work). Repos cloned without a +refs/heads/*:refs/remotes/*
        # refspec won't have that ref, so fall back to the fetched commit.
        echo "  from: origin/$head_branch"
        echo
        git fetch origin "$head_branch"
        if git show-ref --verify --quiet "refs/remotes/origin/$head_branch"; then
            git worktree add -b "$branch" "$target_path" "origin/$head_branch"
        else
            git worktree add -b "$branch" "$target_path" FETCH_HEAD
        fi
    fi

    open_window "$branch"
}

close_window() {
    require_repo

    if [ $# -lt 1 ]; then
        echo "Error: Usage: wt close <worktree>" >&2
        echo "  <worktree> may be a path, branch name, or worktree directory name" >&2
        exit 1
    fi

    resolve_worktree "$1"
    local wt_path="$RESOLVED_PATH" branch="$RESOLVED_BRANCH"

    local primary_worktree
    primary_worktree=$(git worktree list --porcelain | awk '/^worktree / {print substr($0, 10); exit}')
    if [ "$wt_path" = "$primary_worktree" ]; then
        echo "Error: Refusing to close the primary worktree: $wt_path" >&2
        exit 1
    fi

    local label="$branch"
    if [ -z "$label" ] || [ "$label" = "(detached)" ]; then
        label=$(basename "$wt_path")
    fi

    # Close any tmux windows whose panes live in this worktree. Match by pane
    # path rather than window name, since shells rename windows from their
    # prompt hooks after 'wt open' sets the name. The window we're running in
    # (if any) is deferred until after the lock below, so closing our own
    # window can't abort the rest of the operation.
    local kill_current=0 current_wid=""
    if [ -n "${TMUX:-}" ]; then
        current_wid=$(tmux display-message -p '#{window_id}' 2>/dev/null || true)

        declare -A seen_windows
        local window_ids=() line wid ppath
        while IFS= read -r line; do
            wid="${line%% *}"
            ppath="${line#* }"
            if [ "$ppath" = "$wt_path" ] || [[ "$ppath" == "$wt_path"/* ]]; then
                if [ -z "${seen_windows[$wid]:-}" ]; then
                    seen_windows["$wid"]=1
                    window_ids+=("$wid")
                fi
            fi
        done < <(tmux list-panes -a -F '#{window_id} #{pane_current_path}' 2>/dev/null)

        if [ ${#window_ids[@]} -eq 0 ]; then
            echo "No open tmux windows found for: $label"
        else
            for wid in "${window_ids[@]}"; do
                if [ -n "$current_wid" ] && [ "$wid" = "$current_wid" ]; then
                    kill_current=1
                    continue
                fi
                tmux kill-window -t "$wid" 2>/dev/null || true
            done
            echo "Closed ${#window_ids[@]} tmux window(s) for: $label"
        fi
    else
        echo "Not inside a tmux session; skipping pane cleanup"
    fi

    # Lock the worktree so it is parked (and eligible for 'wt cleanup').
    local locked_flag=""
    while IFS=$'\t' read -r p status; do
        if [ "$p" = "$wt_path" ]; then
            locked_flag="$status"
            break
        fi
    done < <(get_worktrees)

    if [ "$locked_flag" = "1" ]; then
        echo "Already locked: $wt_path"
    else
        git worktree lock "$wt_path"
        echo "Locked: $wt_path"
    fi

    # Finally close the window we're running in, if it belonged to this worktree.
    if [ "$kill_current" -eq 1 ]; then
        tmux kill-window -t "$current_wid" 2>/dev/null || true
    fi
}

case "${1:-help}" in
    clone)
        shift
        clone_repo "$@"
        ;;
    init)
        shift
        init_repo "$@"
        ;;
    status|st)
        shift
        status_worktrees "$@"
        ;;
    list|ls)
        list_worktrees
        ;;
    locked)
        list_locked
        ;;
    add|new)
        shift
        add_worktree "$@"
        ;;
    checkout|co)
        shift
        checkout_worktree "$@"
        ;;
    cleanup|clean)
        cleanup_locked
        ;;
    lock)
        shift
        lock_worktree "$@"
        ;;
    unlock)
        shift
        unlock_worktree "$@"
        ;;
    run|exec)
        shift
        run_in_worktrees "$@"
        ;;
    open|o)
        shift
        open_window "$@"
        ;;
    open-pr|pr)
        shift
        open_pr "$@"
        ;;
    close|c)
        shift
        close_window "$@"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo "Error: Unknown command '$1'" >&2
        echo
        usage
        exit 1
        ;;
esac
