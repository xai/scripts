#!/usr/bin/env bash
#
# kernel-build-sign — compile + Secure-Boot-sign a mainline kernel, or sign a
# prebuilt one, for a Secure-Boot + LUKS machine (threefour: Ubuntu 26.04,
# i915 Arrow Lake, dracut initramfs).
#
# Why this exists: the linux 7.0.x i915 PHY regression breaks display modeset +
# Thunderbolt DP tunnels; the fix is upstream in 7.1-rc1 (commit afe3f7471623).
# The 26.04 archive only ships (regressed) 7.0.x, and mainline builds are
# unsigned, so booting a newer kernel needs a self-signed key (MOK) — Secure
# Boot stays ON. See workstation-bootstrap:
#   issues/2026-06-25-threefour-wd19tb-gdm-initrd.md
#
# Subcommands:
#   mok-setup            one-time: generate a signing key + import it (then reboot to enroll)
#   build <ver|tarball>  download/compile a kernel, install, sign, verify (keeps the old kernel)
#   sign  <kver>         MOK-sign an already-installed /boot/vmlinuz-<kver> (e.g. a mainline .deb)
#
# Env overrides: MOK_DIR, KERNEL_BUILD_DIR, KERNEL_BUILD_LOG, JOBS, LOCALVERSION
set -euo pipefail

MOK_DIR="${MOK_DIR:-$HOME/.config/kernel-signing}"
MOK_KEY="$MOK_DIR/MOK.priv"
MOK_PEM="$MOK_DIR/MOK.pem"
MOK_DER="$MOK_DIR/MOK.der"
BUILD_DIR="${KERNEL_BUILD_DIR:-$HOME/kernel-build}"
JOBS="${JOBS:-$(nproc)}"
LOCALVERSION="${LOCALVERSION:-}"
BUILD_LOG="${KERNEL_BUILD_LOG:-$HOME/kernel-build-times.csv}"

die()  { echo "ERROR: $*" >&2; exit 1; }
info() { printf '\033[1;34m>>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!!\033[0m %s\n' "$*" >&2; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing '$1' — apt install ${2:-$1}"; }

# Append one row (date, host, kernel version, CPU/mem, duration) to a CSV in $HOME
# so compile times stay comparable across machines + kernels. Header written once.
log_build_time() {
  local krel="$1" arg="$2" seconds="$3"
  local ts host cores src cpu mem hms
  ts="$(date -Is)"
  host="$(hostname)"
  cores="$(nproc)"
  src="$(basename -- "$arg")"
  cpu="$(LC_ALL=C lscpu 2>/dev/null | sed -n 's/^Model name:[[:space:]]*//p' | head -1)" || true
  if [[ -z "$cpu" ]]; then
    cpu="$(sed -n 's/^model name[[:space:]]*:[[:space:]]*//p' /proc/cpuinfo 2>/dev/null | head -1)" || true
  fi
  mem="$(awk '/^MemTotal:/ {printf "%.1fGiB", $2/1048576}' /proc/meminfo 2>/dev/null)" || true
  hms="$(printf '%d:%02d:%02d' $((seconds/3600)) $((seconds%3600/60)) $((seconds%60)))"
  mkdir -p "$(dirname -- "$BUILD_LOG")"
  [[ -f "$BUILD_LOG" ]] || \
    echo 'timestamp,host,kernel_release,source,cpu_model,cores,jobs,mem_total,compile_seconds,compile_hms' >"$BUILD_LOG"
  printf '%s,%s,%s,"%s","%s",%s,%s,%s,%s,%s\n' \
    "$ts" "$host" "$krel" "$src" "$cpu" "$cores" "$JOBS" "$mem" "$seconds" "$hms" >>"$BUILD_LOG"
  info "Compile time: ${hms} (${seconds}s) — logged to $BUILD_LOG"
}

require_mok() {
  [[ -f "$MOK_KEY" && -f "$MOK_PEM" ]] || die "no MOK key in $MOK_DIR — run: $0 mok-setup"
  local mokchk; mokchk="$(mokutil --test-key "$MOK_DER" 2>&1)" || true
  if ! grep -q "is already enrolled" <<<"$mokchk"; then
    warn "MOK is not enrolled yet — a kernel signed with it will NOT boot until you"
    warn "run 'mok-setup' and complete enrollment at the MokManager screen on reboot."
  fi
}

cmd_mok_setup() {
  need openssl; need mokutil
  mkdir -p "$MOK_DIR"; chmod 700 "$MOK_DIR"
  if [[ -f "$MOK_KEY" ]]; then
    warn "MOK key already exists at $MOK_KEY — keeping it."
  else
    info "Generating MOK signing key (4096-bit, 10y) in $MOK_DIR"
    openssl req -new -x509 -newkey rsa:4096 -nodes -days 3650 \
      -keyout "$MOK_KEY" -out "$MOK_PEM" -subj "/CN=threefour local kernel signing/"
    openssl x509 -in "$MOK_PEM" -outform DER -out "$MOK_DER"
    chmod 600 "$MOK_KEY"
  fi
  info "Importing the public key into the MOK list (set a one-time enrollment password)"
  sudo mokutil --import "$MOK_DER"
  cat <<EOF

NEXT: reboot. At the blue "MOK management" screen pick:
  Enroll MOK -> Continue -> Yes -> (enter the password you just set)
Verify afterwards:  mokutil --test-key $MOK_DER

KEEP $MOK_KEY SECRET (store it in KeePass): anything signed with it boots on this
machine under Secure Boot. It is intentionally NOT in any git repo.
EOF
}

cmd_sign() {
  local kver="${1:?usage: $0 sign <kver>   (e.g. 7.1.0)}"
  need sbsign sbsigntool; need sbverify sbsigntool
  require_mok
  local img="/boot/vmlinuz-$kver"
  [[ -f "$img" ]] || die "no kernel image at $img"
  if sbverify --cert "$MOK_PEM" "$img" >/dev/null 2>&1; then
    info "$img is already signed with this MOK — nothing to do."
    return 0
  fi
  info "Signing $img with the MOK"
  sudo sbsign --key "$MOK_KEY" --cert "$MOK_PEM" --output "$img.signed" "$img"
  sudo mv "$img.signed" "$img"
  sbverify --cert "$MOK_PEM" "$img" >/dev/null || die "signature verification FAILED"
  info "Signed + verified. Refreshing GRUB."
  sudo update-grub
  info "Done. Reboot and pick $kver from the GRUB menu."
}

cmd_build() {
  local arg="${1:?usage: $0 build <version|tarball>   (e.g. 7.1.0, or ./linux-7.1-rc1.tar.gz)}"
  need make; need gcc; need tar; need dracut; need openssl
  require_mok

  info "Installing build dependencies"
  sudo apt-get install -y --no-install-recommends \
    build-essential flex bison libssl-dev libelf-dev libdw-dev bc kmod cpio zstd sbsigntool dracut

  mkdir -p "$BUILD_DIR"
  local tarball
  if [[ -f "$arg" ]]; then
    tarball="$(readlink -f "$arg")"
  else
    local ver="$arg" major="${arg%%.*}" url
    if [[ "$ver" == *rc* ]]; then
      # release candidates are git snapshots, not on the stable CDN
      url="https://git.kernel.org/torvalds/t/linux-${ver}.tar.gz"
      tarball="$BUILD_DIR/linux-${ver}.tar.gz"
    else
      # kernel.org names the first release of a series 'X.Y', not 'X.Y.0'
      local rel="${ver%.0}"
      url="https://cdn.kernel.org/pub/linux/kernel/v${major}.x/linux-${rel}.tar.xz"
      tarball="$BUILD_DIR/linux-${rel}.tar.xz"
    fi
    if [[ ! -f "$tarball" ]]; then
      info "Downloading $url"
      if command -v curl >/dev/null; then curl -fL --retry 3 -o "$tarball" "$url"; else wget -O "$tarball" "$url"; fi \
        || die "download failed (HTTP error). Check https://www.kernel.org for the current version (first release of a series is 'X.Y', not 'X.Y.0'), or pass a tarball path."
    fi
  fi

  local srcdir="$BUILD_DIR/$(tar tf "$tarball" | head -1 | cut -d/ -f1)"
  if [[ -d "$srcdir" ]]; then
    info "Reusing existing source tree $srcdir (delete it for a clean build)"
  else
    info "Extracting $tarball"
    tar -C "$BUILD_DIR" -xf "$tarball"
  fi
  [[ -d "$srcdir" ]] || die "could not find extracted source dir"
  cd "$srcdir"

  info "Seeding config from the running kernel ($(uname -r)) + applying fixes"
  cp "/boot/config-$(uname -r)" .config
  make olddefconfig
  # Build-with-Ubuntu-config gotchas + keep module signing (so modules load under lockdown):
  ./scripts/config --set-str SYSTEM_TRUSTED_KEYS ""      # don't require Canonical's cert
  ./scripts/config --set-str SYSTEM_REVOCATION_KEYS ""
  ./scripts/config --disable DEBUG_INFO_BTF              # avoids pahole-version build breakage
  ./scripts/config --enable  MODULE_SIG --enable MODULE_SIG_ALL
  ./scripts/config --set-str MODULE_SIG_KEY "certs/signing_key.pem"  # default path → kbuild auto-generates + embeds the key; the kernel then trusts its own modules
  ./scripts/config --set-str MODULE_SIG_HASH "sha256"
  [[ -n "$LOCALVERSION" ]] && ./scripts/config --set-str LOCALVERSION "$LOCALVERSION"
  make olddefconfig
  local krel; krel="$(make -s kernelrelease)"
  info "Will build + install kernel release: $krel  (jobs=$JOBS)"
  read -rp "Proceed with the full build? [y/N] " ans; [[ "$ans" == [yY]* ]] || die "aborted."

  info "Compiling (this takes a while)"
  SECONDS=0
  make -j"$JOBS"
  log_build_time "$krel" "$arg" "$SECONDS"
  info "Installing modules (stripped + signed) and kernel image"
  sudo make INSTALL_MOD_STRIP=1 modules_install
  sudo install -m 0644 "$(make -s image_name)" "/boot/vmlinuz-$krel"
  sudo install -m 0644 System.map "/boot/System.map-$krel"
  sudo install -m 0644 .config "/boot/config-$krel"

  info "Building the initramfs with dracut for $krel"
  sudo dracut --force "/boot/initrd.img-$krel" "$krel"

  # --- LUKS safety gate: this box has encrypted root; the initramfs MUST be able to
  #     unlock it and accept keyboard input, or you're locked out at boot. ---
  local initrd="/boot/initrd.img-$krel"
  [[ -f "$initrd" ]] || die "initramfs $initrd was not created"
  info "Sanity-checking the initramfs can unlock LUKS + take keyboard"
  # Capture once and match with here-strings: `lsinitrd | grep -q` would let grep
  # close the pipe early, SIGPIPE lsinitrd, and (with pipefail) falsely report "no match".
  local listing; listing="$(sudo lsinitrd "$initrd" 2>/dev/null)" || true
  grep -qiE 'crypt' <<<"$listing" \
    || die "NO crypt support in initramfs — DO NOT boot $krel (LUKS lockout). Old kernel $(uname -r) is still your default."
  grep -qiE 'usbhid|hid_generic|hid-generic|/hid|/keyboard' <<<"$listing" \
    || warn "No obvious HID/keyboard module in the initramfs — verify you can type the LUKS passphrase; keep $(uname -r) as a fallback."

  cmd_sign "$krel"

  cat <<EOF

============================================================================
 Built, signed, and GRUB-updated:  $krel
 Fallback kernel still installed:  $(uname -r)   (pick it from the GRUB menu if needed)

 Reboot, then at the GRUB menu choose "Advanced options" -> $krel.
 First-boot checklist:
   1. LUKS passphrase prompt accepts your keyboard, unlocks, boots.
   2. uname -r        -> $krel
   3. dmesg | grep -i 'module verification'   (should be quiet; no unsigned-module errors)
   4. journalctl -k | grep -iE 'refclk|tearing down'   (the regression should be gone)
   5. dock the externals and confirm DP-4/DP-5 come up.
 If anything misbehaves: reboot and pick $(uname -r). Nothing was removed.
============================================================================
EOF
}

case "${1:-help}" in
  mok-setup) shift; cmd_mok_setup "$@" ;;
  build)     shift; cmd_build "$@" ;;
  sign)      shift; cmd_sign "$@" ;;
  *) sed -n '3,30p' "$0"; exit 0 ;;
esac
